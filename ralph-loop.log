+        mock_executor.__exit__ = MagicMock(return_value=False)
+
+        # submit order mirrors uncached list — good first, bad second
+        mock_executor.submit.side_effect = [good_future, bad_future]
+
+        with patch(
+            "playchitect.core.intensity_analyzer.ProcessPoolExecutor",
+            return_value=mock_executor,
+        ):
+            with patch(
+                "playchitect.core.intensity_analyzer.as_completed",
+                return_value=[good_future, bad_future],
+            ):
+                analyzer = IntensityAnalyzer(cache_dir=tmp_path, cache_enabled=False)
+                results = analyzer.analyze_batch([good_path, bad_path])
+
+        # Only the good file should appear in results
+        assert good_path in results
+        assert bad_path not in results
+        assert results[good_path].rms_energy == 0.5
+
