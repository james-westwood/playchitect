+def _build_tags_section(self) -> None:
+    """Build the vibe tags section with chip display and input."""
+    # Tags label
+    tags_label = Gtk.Label(label="Tags")
+    tags_label.set_xalign(0.0)
+    tags_label.add_css_class("heading")
+    self.append(tags_label)
+
+    # FlowBox for tag chips
+    self._tags_flow_box = Gtk.FlowBox()
+    self._tags_flow_box.set_selection_mode(Gtk.SelectionMode.NONE)
+    self._tags_flow_box.set_max_children_per_line(5)
+    self._tags_flow_box.set_column_spacing(6)
+    self._tags_flow_box.set_row_spacing(6)
+    self._tags_flow_box.set_homogeneous(False)
+    self.append(self._tags_flow_box)
+
+    # Tag input row
+    input_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
+    input_box.set_margin_top(6)
+
+    # Entry with completion
+    self._tag_entry = Gtk.Entry()
+    self._tag_entry.set_placeholder_text("Add tag...")
+    self._tag_entry.set_hexpand(True)
+    self._tag_entry.connect("activate", self._on_tag_entry_activated)
+    input_box.append(self._tag_entry)
+
+    # EntryCompletion for auto-complete
+    self._tag_completion = Gtk.EntryCompletion()
+    self._tag_completion.set_inline_completion(True)
+    self._tag_completion.set_popup_completion(True)
+    self._tag_completion.set_popup_single_match(False)
+    self._tag_entry.set_completion(self._tag_completion)
+
+    # ListStore for completion model
+    self._completion_model = Gtk.ListStore(str)
+    self._tag_completion.set_model(self._completion_model)
+    self._tag_completion.set_text_column(0)
+
+    # Add button
+    add_btn = Gtk.Button.new_from_icon_name("list-add-symbolic")
+    add_btn.set_tooltip_text("Add tag")
+    add_btn.connect("clicked", self._on_add_tag_clicked)
+    input_box.append(add_btn)
+
+    self.append(input_box)
+
+def _update_tags_display(self) -> None:
+    """Refresh the tag chips display for current track."""
+    # Clear existing chips
+    while self._tags_flow_box.get_first_child():
+        self._tags_flow_box.remove(self._tags_flow_box.get_first_child())
+
+    if self._current_track is None:
+        return
+
+    track_path = Path(self._current_track.filepath)
+    tags = self._tag_store.get_tags(track_path)
+
+    for tag in tags:
+        chip = self._create_tag_chip(tag)
+        self._tags_flow_box.append(chip)
+
+def _create_tag_chip(self, tag: str) -> Gtk.Button:
+    """Create a tag chip button with dismiss option.
+
+    Args:
+        tag: Tag text to display
+
+    Returns:
+        Gtk.Button configured as a tag chip
+    """
+    chip = Gtk.Button(label=f"{tag} ×")
+    chip.add_css_class("tag-chip")
+    chip.add_css_class("pill")
+    chip.set_tooltip_text(f"Click to remove '{tag}'")
+    chip.connect("clicked", self._on_tag_chip_clicked, tag)
+    return chip
+
+def _on_tag_chip_clicked(self, _btn: Gtk.Button, tag: str) -> None:
+    """Handle tag chip click - remove the tag."""
+    if self._current_track is None:
+        return
+
+    track_path = Path(self._current_track.filepath)
+    self._tag_store.remove_tag(track_path, tag)
+    self._update_tags_display()
+    self._refresh_completion_model()
+
+def _on_tag_entry_activated(self, entry: Gtk.Entry) -> None:
+    """Handle Enter key in tag entry."""
+    self._add_tag_from_entry(entry)
+
+def _on_add_tag_clicked(self, _btn: Gtk.Button) -> None:
+    """Handle add tag button click."""
+    self._add_tag_from_entry(self._tag_entry)
+
+def _add_tag_from_entry(self, entry: Gtk.Entry) -> None:
+    """Add tag from entry text if valid."""
+    text = entry.get_text().strip()
+    if not text or self._current_track is None:
+        return
+
+    track_path = Path(self._current_track.filepath)
+    self._tag_store.add_tag(track_path, text)
+    entry.set_text("")
+    self._update_tags_display()
+    self._refresh_completion_model()
+
+def _refresh_completion_model(self) -> None:
+    """Update the completion model with all available tags."""
+    self._completion_model.clear()
+    all_tags = self._tag_store.all_tags()
+    for tag in all_tags:
