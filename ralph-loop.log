+class TestCorruptAudioHandling:
+    """Tests that corrupt / unreadable files are handled gracefully."""
+
+    # ------------------------------------------------------------------ helpers
+
+    def _make_dummy_audio_file(self, tmp_path: Path, name: str = "track.mp3") -> Path:
+        """Return a path to a file that 'exists' so FileNotFoundError is not raised."""
+        p = tmp_path / name
+        p.write_bytes(b"not real audio")
+        return p
+
+    # ------------------------------------------------------------------ analyze()
+
+    @pytest.mark.parametrize(
+        "exc",
+        [
+            ValueError("malformed header"),
+            OSError("permission denied"),
+            RuntimeError("decoding failed"),
+            audioread.exceptions.NoBackendError(),
+            soundfile.LibsndfileError(1, "format not recognised"),
+        ],
+    )
+    def test_analyze_returns_zero_vector_on_librosa_load_error(
+        self, tmp_path: Path, exc: Exception
+    ) -> None:
+        """mock librosa.load raising each supported exception → zero-vector, no raise."""
+        filepath = self._make_dummy_audio_file(tmp_path)
+        analyzer = IntensityAnalyzer(cache_enabled=False)
+
+        with patch("playchitect.core.intensity_analyzer.librosa.load", side_effect=exc):
+            result = analyzer.analyze(filepath)
+
+        assert isinstance(result, IntensityFeatures)
+        assert result.rms_energy == 0.0
+        assert result.brightness == 0.0
+        assert result.sub_bass_energy == 0.0
+        assert result.kick_energy == 0.0
+        assert result.bass_harmonics == 0.0
+        assert result.percussiveness == 0.0
+        assert result.onset_strength == 0.0
+        assert result.file_hash == ""
+        assert result.filepath == filepath
+
+    def test_analyze_returns_zero_vector_on_bare_exception(self, tmp_path: Path) -> None:
+        """Bare Exception fallback: unexpected decode error still returns zero-vector."""
+        filepath = self._make_dummy_audio_file(tmp_path)
+        analyzer = IntensityAnalyzer(cache_enabled=False)
+
+        with patch(
+            "playchitect.core.intensity_analyzer.librosa.load",
+            side_effect=Exception("unexpected"),
+        ):
+            result = analyzer.analyze(filepath)
+
+        assert result.rms_energy == 0.0
+
+    def test_analyze_logs_warning_for_corrupt_file(
+        self, tmp_path: Path, caplog: pytest.LogCaptureFixture
+    ) -> None:
+        """A warning containing the filepath must be emitted for corrupt files."""
+        filepath = self._make_dummy_audio_file(tmp_path)
+        analyzer = IntensityAnalyzer(cache_enabled=False)
+
+        with patch(
+            "playchitect.core.intensity_analyzer.librosa.load",
+            side_effect=ValueError("bad file"),
+        ):
+            import logging
+
+            with caplog.at_level(logging.WARNING, logger="playchitect.core.intensity_analyzer"):
+                analyzer.analyze(filepath)
+
+        assert any(str(filepath) in rec.message for rec in caplog.records), (
+            "Expected a warning containing the filepath; got: "
+            + str([r.message for r in caplog.records])
+        )
+
+    def test_analyze_still_raises_file_not_found(self, tmp_path: Path) -> None:
+        """FileNotFoundError must still be raised for genuinely missing files."""
+        analyzer = IntensityAnalyzer(cache_enabled=False)
+        with pytest.raises(FileNotFoundError):
+            analyzer.analyze(tmp_path / "does_not_exist.mp3")
+
+    # ------------------------------------------------------------------ _analyze_worker()
+
+    def test_analyze_worker_returns_none_on_error(self, tmp_path: Path) -> None:
+        """_analyze_worker must return (path_str, None) rather than propagating."""
+        filepath = self._make_dummy_audio_file(tmp_path)
+
+        with patch(
+            "playchitect.core.intensity_analyzer.librosa.load",
+            side_effect=ValueError("corrupt"),
+        ):
+            path_str, result = _analyze_worker((str(filepath), str(tmp_path)))
+
+        assert path_str == str(filepath)
+        assert result is None
+
+    def test_analyze_worker_returns_dict_on_success(self, tmp_path: Path) -> None:
+        """_analyze_worker returns a dict when analysis succeeds."""
+        import numpy as np
+        import soundfile as sf
+
+        sample_rate = 22050
+        audio = np.sin(2 * np.pi * 440 * np.linspace(0, 1, sample_rate)).astype(np.float32)
+        wav_path = tmp_path / "ok.wav"
+        sf.write(wav_path, audio, sample_rate)
+
+        path_str, result = _analyze_worker((str(wav_path), str(tmp_path)))
+
+        assert path_str == str(wav_path)
+        assert result is not None
+        assert "rms_energy" in result
